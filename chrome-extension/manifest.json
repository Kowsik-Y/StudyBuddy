{
  "manifest_version": 3,
  "name": "Study Buddy",
  "version": "1.0.0",
  "description": "Voice assistant, quiz, viva, explain, video Q&A and analytics — all in Chrome.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Study Buddy",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ]
}
